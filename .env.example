# Inova Monitoring Configuration Template
# Copy this file to .env and fill in your values

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=inova_monitoring

# Prometheus Configuration
PROMETHEUS_URL=http://localhost:9090

# SSO and Authentication Configuration
# AUTH_METHODS_ALLOWED=basic,google,github,entra
AUTH_METHODS_ALLOWED=google,github,entra,basic

# Google OAuth
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_id
GITHUB_CLIENT_SECRET=your_github_secret

# Microsoft Entra ID (Azure AD)
ENTRA_ID_CLIENT_ID=your_id
ENTRA_ID_CLIENT_SECRET=your_secret
ENTRA_ID_TENANT_ID=your_tenant_id

# Basic Auth Toggle
ENABLE_BASIC_AUTH=true

# Application Settings
DEBUG=true
API_SECRET_KEY=generate-a-secure-key-here
SECRET_KEY=generate-a-secure-session-key-here
