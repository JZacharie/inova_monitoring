# Inova Monitoring Configuration Template
# Copy this file to .env and fill in your values

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=inova_monitoring

# Prometheus Configuration
PROMETHEUS_URL=http://localhost:9090

# SSO Configuration
SSO_CLIENT_ID=your-client-id
SSO_CLIENT_SECRET=your-client-secret
SSO_AUTH_URL=https://auth.example.com/oauth2/authorize
SSO_TOKEN_URL=https://auth.example.com/oauth2/token

# Application Settings
DEBUG=true
API_SECRET_KEY=generate-a-secure-key-here
